# Restart-Policy fuer alle connector-Container: on-failure.
# Begruendung: Boot-Start passiert via dfld-connectors.service (mit
# Freeze-Marker-Pre-Check), nicht via Docker-Daemon — daher kein
# unless-stopped. on-failure gibt uns trotzdem Crash-Resilienz waehrend
# des Betriebs (z.B. wenn ein Container wegen Sensor-Fehler exit'd).
# Bei Pi-Boot mit Freeze bleibt alles aus; bei Boot ohne Freeze startet
# der systemd-Service alles via 'docker compose up -d'.
services:
  # Unified sensor to MQTT service - replaces individual sensor services
  sensor2mqtt:
    image: dfld_box
    restart: on-failure
    container_name: sensor2mqtt
    entrypoint: python /dfld/sensor2mqtt.py
    # High priority for sensor data collection
    cpu_shares: 1024
    env_file:
      - /opt/dfld/version.env
    environment:
      - DFLD_STATION_ID=${DFLD_REGION}-${DFLD_STATION}
      - MQTT_SERVER=${MQTT_SERVER}
      - MQTT_DATA_TOPIC=dfld/sensors/noise/spl
      - MQTT_META_TOPIC=dfld/metadata/sensors
      - READOUT_INTERVAL_NOISE=1.0
      - READOUT_INTERVAL_AIR=60.0
      - RETRY_INTERVAL=120
      - LOG_LEVEL=INFO
      # DNMS Serial config
      - DNMS_DEVICE=${DNMS_DEVICE:-}
      - DNMS_BAUDRATE=500000
      # DFLD Legacy config
      - AK_MODUL_DEVICE=${AK_MODUL_DEVICE:-}
      - AK_MODUL_BAUDRATE=9600
      # I2C config
      - DNMS_I2C_ADDRESS=0x55
      - BME280_I2C_ADDRESS=0x76
      - I2C_BUS=1
      - DNMS_MICROPHONE_TYPE=${DNMS_MICROPHONE_TYPE:-28}
      # UDP config
      - UDP_LISTEN_PORT=11883
      # System metadata config
      - MQTT_META_SYSTEM_TOPIC=dfld/metadata/system
      - MQTT_META_GEO_TOPIC=dfld/metadata/geo
      - STATION_LAT=${STATION_LAT:-}
      - STATION_LON=${STATION_LON:-}
      - STATION_ALT=${STATION_ALT:-}
      - STATION_CITY=${STATION_CITY:-}
      - STARTUP_DELAY=30
    labels:
      - homepage.group=Infrastructure
      - homepage.name=sensor2mqtt
      - homepage.icon=/icons/thermometer-icon.svg
      - homepage.description=Unified sensor data collector
      - homepage.showStats=true
    networks:
      - network
{% if hw_conf["DNMS_I2C_AVAILABLE"]==0 and hw_conf["DFLD_LEGACY_AVAILABLE"]==0 and hw_conf["DFLD_DNMS_AVAILABLE"]==0 %}
    # No hardware sensors detected, only UDP listener active
    ports:
      - 11883:11883/udp
{% endif %}
    # Required for hardware detection and access
    privileged: true

  mqtt2tsdb:
    image: dfld_box
    restart: on-failure
    container_name: mqtt2tsdb
    entrypoint: python /dfld/mqtt2tsdb.py
    environment:
      - INFLUXDB_USERNAME=${INFLUX_ADMIN_USERNAME}
      - INFLUXDB_PASSWORD=${INFLUX_ADMIN_PASSWORD}
      - INFLUXDB_DATABASE=${INFLUXDB_DATABASE}
      - INFLUXDB_SERVER=${INFLUXDB_SERVERNAME}:${INFLUXDB_SERVERPORT}
      - MQTT_SERVER=${MQTT_SERVER}
      - MQTT_TOPIC=dfld/sensors/noise/spl/#
      - TZ=${TZ}
      - LOG_LEVEL=INFO
    labels:
      - homepage.group=Infrastructure
      - homepage.name=mqtt2tsdb
      - homepage.icon=/icons/server-upload-icon.svg
      - homepage.description=Push the data home
      - homepage.showStats=true
    networks:
      - network

{% if dfld_legacy is defined and dfld_legacy | length > 0 %}
  tsdb2ftp:
    image: dfld_box
    restart: on-failure
    container_name: tsdb2ftp
    entrypoint: python /dfld/tsdb2ftp.py
    environment:
      - INFLUXDB_USERNAME=${INFLUX_ADMIN_USERNAME}
      - INFLUXDB_PASSWORD=${INFLUX_ADMIN_PASSWORD}
      - INFLUXDB_DATABASE=${INFLUXDB_DATABASE}
      - INFLUXDB_SERVER=${INFLUXDB_SERVERNAME}:${INFLUXDB_SERVERPORT}
      - INFLUXDB_MEASUREMENT=spl
      - DFLD_REGION=${DFLD_REGION}
      - DFLD_STATION=${DFLD_STATION}
      - DFLD_CKSUM=${DFLD_CKSUM}
      - DFLD_LEGACY=${DFLD_LEGACY}
      - TZ=${TZ}
      - LOG_LEVEL=INFO
    labels:
      - homepage.group=Infrastructure
      - homepage.name=tsdb2ftp
      - homepage.icon=/icons/server-upload-icon.svg
      - homepage.description=Export data to FTP
      - homepage.showStats=true
    networks:
      - network

  mqtt2liveview:
    image: dfld_box
    restart: on-failure
    container_name: mqtt2liveview
    entrypoint: python /dfld/mqtt2liveview.py
    environment:
      - MQTT_SERVER=${MQTT_SERVER}
      - MQTT_TOPIC=dfld/sensors/noise/spl/#
      - DFLD_REGION=${DFLD_REGION}
      - DFLD_STATION=${DFLD_STATION}
      - DFLD_CKSUM=${DFLD_CKSUM}
      - DFLD_LIVEVIEW=${DFLD_LIVEVIEW}
      - TZ=${TZ}
      - LOG_LEVEL=INFO
    labels:
      - homepage.group=Infrastructure
      - homepage.name=mqtt2liveview
      - homepage.icon=/icons/server-upload-icon.svg
      - homepage.description=Send data to LiveView
      - homepage.showStats=true
    networks:
      - network
{% endif %}

{% if dfld_backfill_interval is defined and dfld_backfill_interval != "off" %}
  # Pi-seitige Backfill-Komponente: liest aus lokaler InfluxDB und pusht
  # via HTTPS+mTLS an den server-seitigen spl-backfill-Endpoint
  # (https://ingest.dfld.de/backfill/spl/<station>). Intervall steuert
  # das Sleep (hourly = 3600s, daily = 86400s).
  # Architektur: docs/backfill-architecture.md im dfld_server-Repo.
  tsdb2http:
    image: dfld_box
    restart: on-failure
    container_name: tsdb2http
    entrypoint: python /dfld/tsdb2http.py
    environment:
      - INFLUXDB_USERNAME=${INFLUX_ADMIN_USERNAME}
      - INFLUXDB_PASSWORD=${INFLUX_ADMIN_PASSWORD}
      - INFLUXDB_DATABASE=${INFLUXDB_DATABASE}
      - INFLUXDB_SERVER=${INFLUXDB_SERVERNAME}:${INFLUXDB_SERVERPORT}
      - INFLUXDB_MEASUREMENT=spl
      - DFLD_REGION=${DFLD_REGION}
      - DFLD_STATION=${DFLD_STATION}
      # ${VAR:-...}-Syntax laesst den User per dfld.yml-Edit ueberschreiben
      # (dfld-generate-env.sh schreibt nach dfld_user.env, systemd-path-watcher
      # reloaded den Container, kein Re-Deploy noetig).
      # Beide Env-Namen werden gesetzt — sowohl alte als auch neue
      # tsdb2http.py-Variante laeuft. Cross-Version-Sicherheit fuer den
      # Roll-out-Zeitpunkt wo Image evtl. noch alt ist (build-images-Role
      # rebuildet nicht wenn Image existiert).
      - DFLD_BACKFILL_INTERVAL=${DFLD_BACKFILL_INTERVAL:-{{ dfld_backfill_interval }}}
      - DFLD_TX_TIER=${DFLD_TX_TIER:-{{ dfld_backfill_interval }}}
{% if dfld_ingest_url is defined and dfld_ingest_url | length > 0 %}
      - DFLD_INGEST_URL=${DFLD_INGEST_URL:-{{ dfld_ingest_url }}}
{% endif %}
      - TZ=${TZ}
      - LOG_LEVEL=INFO
    volumes:
      - {{ dfld_dir }}/certs:/certs:ro
      - {{ dfld_dir }}/tsdb2http:/var/lib/tsdb2http
    labels:
      - homepage.group=Infrastructure
      - homepage.name=tsdb2http
      - homepage.icon=/icons/server-upload-icon.svg
      - homepage.description=Backfill SPL via HTTPS ({{ dfld_backfill_interval }})
      - homepage.showStats=true
    networks:
      - network
{% endif %}

{% if osm_station_id is defined and osm_station_id | length > 0 and osm_sensors is defined and osm_sensors | length > 0 and osm_api_key is defined and osm_api_key | length > 0 %}
  tsdb2osm:
    image: dfld_box
    restart: on-failure
    container_name: tsdb2osm
    entrypoint: python /dfld/tsdb2osm.py
    environment:
      - INFLUXDB_USERNAME=${INFLUX_ADMIN_USERNAME}
      - INFLUXDB_PASSWORD=${INFLUX_ADMIN_PASSWORD}
      - INFLUXDB_SERVER=${INFLUXDB_SERVERNAME}:${INFLUXDB_SERVERPORT}
      - OSM_STATION_ID=${OSM_STATION_ID}
      - OSM_SENSORS=${OSM_SENSORS}
      - OSM_API_KEY=${OSM_API_KEY}
      - OSM_INTERVAL=${OSM_INTERVAL:-300}
      - OSM_API_URL=${OSM_API_URL:-https://api.opensensemap.org}
      - TZ=${TZ}
      - LOG_LEVEL=INFO
    labels:
      - homepage.group=Infrastructure
      - homepage.name=tsdb2osm
      - homepage.icon=/icons/server-upload-icon.svg
      - homepage.description=Export data to openSenseMap
      - homepage.showStats=true
    networks:
      - network
{% endif %}

{# mqtt2mqtt = Live-MQTT-Bridge zum DFLD-Server. Gating-Logik:
   - mqtt_bridged_broker + mqtt_bridged_rename muessen konfiguriert sein (was-bridgen)
   - dfld_live_enabled muss true sein (ob-bridgen). Default true via inventory.
   Default-true heisst: Bestandsstationen ohne dfld_live_enabled-Feld in
   dfld.yml verhalten sich wie bisher. #}
{% if mqtt_bridged_broker is defined and mqtt_bridged_broker | length > 0 and mqtt_bridged_rename is defined and mqtt_bridged_rename | length > 0 and (dfld_live_enabled | default(true)) %}
  mqtt2mqtt:
    image: dfld_box
    restart: on-failure
    container_name: mqtt2mqtt
    entrypoint: python /dfld/mqtt2mqtt.py
    env_file:
      - ${DOCKER_EXTERNAL_ROOT}/connectors/dfld_user.env
    environment:
      - DFLD_STATION_ID=dfld-${DFLD_REGION}-${DFLD_STATION}
      - MQTT_SERVER=${MQTT_SERVER}
      - MQTT_BRIDGED_BROKER=${MQTT_BRIDGED_BROKER}
      - MQTT_BRIDGED_RENAME=${MQTT_BRIDGED_RENAME}
      - MQTT_BRIDGED_TLS=${MQTT_BRIDGED_TLS}
      - MQTT_TLS_CA_CERT=/certs/ca-cert.pem
      - MQTT_TLS_CLIENT_CERT=/certs/client-cert.pem
      - MQTT_TLS_CLIENT_KEY=/certs/client-key.pem
      - MQTT_TLS_INSECURE=false
      - LOG_LEVEL=INFO
    volumes:
      - /etc/ssl/certs:/etc/ssl/certs:ro
      - ${DOCKER_EXTERNAL_ROOT}/certs:/certs:ro
    labels:
      - homepage.group=Infrastructure
      - homepage.name=mqtt2mqtt
      - homepage.icon=/icons/server-upload-icon.svg
      - homepage.description=Bridge to remote MQTT broker
      - homepage.showStats=true
    networks:
      - network
{% endif %}

{% if deployment_mode == "full" and hw_conf["ADSB_AVAILABLE"] == 1 %}
